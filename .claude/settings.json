{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "AXIS framework — versioned harness for the framework repo itself. Permissions are conservative: this repo is documentation + scripts, not application code.",
  "permissions": {
    "allow": [
      "Read(**)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(ln -sf:*)",
      "Bash(mkdir -p:*)",
      "Bash(./setup-ide-links.sh:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.env.*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Write(FRAMEWORK.md)",
      "Write(README.md)",
      "Write(README.pt.md)"
    ]
  }
}
